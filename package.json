{
  "name": "nuxt-starter-kit",
  "version": "2.0",
  "description": "A Nuxt 4 starter template with NuxtHub, Auth, and PWA support",
  "author": {
    "name": "No Name Studio",
    "email": "contact@nnsvn.me"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run prepare && node --max-old-space-size=8192 node_modules/.bin/nuxt build",
    "clean": "rm -r .nuxt && rm -r .output",
    "db:generate": "npx nuxt db generate",
    "db:seed": "nitro task run db:admin-creation",
    "deploy": "npx wrangler --cwd .output deploy && npx wrangler --cwd .output d1 migrations apply DB --remote",
    "dev": "npm run prepare && nuxt dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "nuxt prepare",
    "prepare": "pwa-assets-generator",
    "preview": "nuxt preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@lucide/vue": "^1.8.0",
    "@nuxt/content": "^3.13.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/tailwindcss": "^7.0.0-beta.1",
    "@nuxtjs/turnstile": "^1.1.2",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.49.0",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.24",
    "@unhead/vue": "^2.1.13",
    "@vee-validate/nuxt": "^5.0.0-beta.1",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.2.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "echarts": "^6.0.0",
    "es-toolkit": "^1.45.1",
    "feed": "^5.2.0",
    "luxon": "^3.7.2",
    "minisearch": "^7.2.0",
    "motion-v": "^2.2.1",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-component-meta": "^0.17.2",
    "nuxt-content-git": "^7.0.0",
    "nuxt-security": "^2.5.1",
    "nuxt-studio": "^1.6.0",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.8.1",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-input-otp": "^0.3.2",
    "vue-sonner": "^2.0.9",
    "vue3-simple-icons": "^16.10.0",
    "zod": "^4.3.6"
  },
